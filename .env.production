# Production build config (npm run build) — CI builds from THIS file only;
# the local .env is gitignored, so every runtime-required var must be here.
# Draco models only — the .ktx textures are stale for customized labels;
# regenerate them with toktx before switching to VITE_COMPRESSED=1
VITE_COMPRESSED_MODELS=1
VITE_MUSIC=1
VITE_LOG=1
VITE_WHISPERS_COUNT=30

# Declared empty on purpose (referenced by the code, off in production) so
# the build bakes them in and the smoke test can verify nothing is missing
VITE_COMPRESSED=
VITE_DAY_CYCLE_PROGRESS=
VITE_YEAR_CYCLE_PROGRESS=
VITE_PLAYER_SPAWN=
VITE_GAME_PUBLIC=

# Circuit leaderboard + altar counter backend (server/ directory,
# deployed to Cloudflare Workers with: cd server && npx wrangler deploy)
VITE_SERVER_URL=wss://prakash-folio-server.kantamaniprakash.workers.dev
