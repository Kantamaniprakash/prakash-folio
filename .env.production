# Production build overrides (npm run build)
# Draco models only — the .ktx textures are stale for customized labels;
# regenerate them with toktx before switching to VITE_COMPRESSED=1
VITE_COMPRESSED_MODELS=1

# Circuit leaderboard + altar counter backend (server/ directory,
# deployed to Cloudflare Workers with: cd server && npx wrangler deploy)
VITE_SERVER_URL=wss://prakash-folio-server.kantamaniprakash.workers.dev
