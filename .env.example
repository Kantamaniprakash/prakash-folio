# Copy this file to .env for local development (the .env file is gitignored).
# All variables are read at build/dev time by Vite (import.meta.env.*).
# See .env.production for the exact values used by the CI production build.

# Load Draco-compressed .glb models from static/ (1 = on, empty = off)
VITE_COMPRESSED_MODELS=1

# Enable music playback (1 = on, empty = off)
VITE_MUSIC=1

# Enable console logging (1 = on, empty = off)
VITE_LOG=1

# Number of "whisper" messages spawned in the world
VITE_WHISPERS_COUNT=30

# Load KTX-compressed textures (leave empty until textures are regenerated with toktx)
VITE_COMPRESSED=

# Debug overrides — leave empty for normal behavior
VITE_DAY_CYCLE_PROGRESS=
VITE_YEAR_CYCLE_PROGRESS=
VITE_PLAYER_SPAWN=
VITE_GAME_PUBLIC=

# WebSocket backend for the circuit leaderboard + altar counter
# (server/ directory, deployed to Cloudflare Workers — not a secret)
VITE_SERVER_URL=wss://your-worker-name.your-account.workers.dev
